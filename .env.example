DATABASE_URL=sqlite:///./tazabak.db
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=5242880
MAX_IMAGE_PIXELS=16000000
SEED_DEMO_DATA=true
# In production the application refuses to start with the demo key below.
# Set APP_ENV=production and inject a unique secret.
APP_ENV=development
DISPATCHER_API_KEY=123
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https?://(?:(?:localhost|127\.0\.0\.1)|(?:10(?:\.\d{1,3}){3})|(?:192\.168(?:\.\d{1,3}){2})|(?:172\.(?:1[6-9]|2\d|3[0-1])(?:\.\d{1,3}){2}))(?::\d+)?

# Physical dimensions of the municipal prototype: empty at 25 cm, full at 7 cm.
H_EMPTY_CM=25
H_FULL_CM=7
EMA_ALPHA=0.3
# Device IDs that must never accept municipal telemetry again.
RETIRED_MUNICIPAL_DEVICE_IDS=municipal-rio-001

# One DS18B20 is installed inside the bin. Any reading strictly above this
# threshold immediately creates FIRE_RISK and requests CLOSE_LID.
FIRE_TEMPERATURE_THRESHOLD_C=50
# FireScore remains telemetry diagnostics and does not decide the safety alert.
FIRE_WEIGHT_DELTA=0.7
FIRE_WEIGHT_RATE=0.3
MIN_RATE_INTERVAL_SECONDS=1
WEBSOCKET_SEND_TIMEOUT_SECONDS=2

# Keep the real key only in local environment/secret manager. Never commit it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-flash-latest
GEMINI_TIMEOUT_SECONDS=15
GEMINI_MAX_OUTPUT_TOKENS=500

VISION_DETECTION_PROBABILITY=0.35
CAMERA_ANALYSIS_ENABLED=true
CAMERA_ANALYSIS_INTERVAL_SECONDS=5
CAMERA_CAPTURE_TIMEOUT_SECONDS=5
CAMERA_ALERT_COOLDOWN_SECONDS=300
CAMERA_FRAME_RETENTION=100
# A single object from this list, or 3 other non-background objects, triggers ILLEGAL_DUMP.
CAMERA_ILLEGAL_DUMP_MIN_OBJECTS=3
CAMERA_ILLEGAL_DUMP_CLASSES=bottle,cup,bowl,banana,apple,orange,sandwich,backpack,handbag,suitcase
BIO_REWARD_POINTS=15
NFT_PRICE_POINTS=100
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.25
YOLO_DEVICE=cpu
YOLO_BREAD_CLASSES=sandwich,cake,donut,pizza,hot dog
YOLO_MOLD_CLASSES=broccoli,dining table
