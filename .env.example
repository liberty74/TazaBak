DATABASE_URL=sqlite:///./tazabak.db
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=5242880
MAX_IMAGE_PIXELS=16000000
SEED_DEMO_DATA=true
# In production the application refuses to start with the demo key below.
# Set APP_ENV=production and inject a unique secret.
APP_ENV=development
DISPATCHER_API_KEY=123
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

H_EMPTY_CM=100
H_FULL_CM=10
EMA_ALPHA=0.3

FIRE_WEIGHT_DELTA=0.7
FIRE_WEIGHT_RATE=0.3
FIRE_THRESHOLD=15
FIRE_REQUIRED_STREAK=2
MIN_RATE_INTERVAL_SECONDS=1
WEBSOCKET_SEND_TIMEOUT_SECONDS=2

# Keep the real key only in local environment/secret manager. Never commit it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-flash-latest
GEMINI_TIMEOUT_SECONDS=15
GEMINI_MAX_OUTPUT_TOKENS=500

VISION_DETECTION_PROBABILITY=0.35
BIO_REWARD_POINTS=15
NFT_PRICE_POINTS=100
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.25
YOLO_DEVICE=cpu
YOLO_BREAD_CLASSES=sandwich,cake,donut,pizza,hot dog
YOLO_MOLD_CLASSES=broccoli,dining table
